PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_NAME=remnant_orvex_capital
DB_USER=app_user
DB_PASSWORD=change_me
APP_DB_USER=
APP_DB_PASSWORD=
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=10000

# Generate a random 32+ character value and keep it server-only.
JWT_SECRET=replace_with_a_long_random_secret_value

# Auth hardening
BCRYPT_ROUNDS=12
SESSION_TTL_MINUTES=60
EMAIL_VERIFICATION_TTL_MINUTES=15
PASSWORD_RESET_TTL_MINUTES=15
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_MAX_FAILURES=5
AUTH_COOKIE_NAME=roc_session
AUTH_COOKIE_SAME_SITE=strict
AUTH_COOKIE_SECURE=false
TRUST_PROXY=1
JOB_RUNNER=false
SHUTDOWN_TIMEOUT_MS=10000

# Browser + email links
PUBLIC_API_URL=http://localhost:5000
PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Email delivery for verification and password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Protect the public KYC webhook endpoint.
KYC_WEBHOOK_SECRET=

# Optional bootstrap admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
